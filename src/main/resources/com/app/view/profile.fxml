<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Group?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<AnchorPane fx:id="rootPane" onMouseDragged="#onWindowDragged" onMousePressed="#onWindowPressed" prefHeight="750.0" prefWidth="1000.0" styleClass="main-app-pane" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.app.controller.ProfileController">
   <children>
      <!-- Centering Container -->
      <StackPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="650.0" prefWidth="850.0" styleClass="profile-card-elite">
               <clip>
                  <Rectangle arcHeight="30.0" arcWidth="30.0" height="650.0" width="850.0" />
               </clip>
               
               <children>
                  <!-- Header Section -->
                  <VBox alignment="CENTER" prefHeight="220.0" prefWidth="850.0" styleClass="profile-header-premium">
                     <children>
                        <HBox alignment="CENTER" spacing="30.0">
                           <children>
                              <VBox alignment="CENTER" spacing="12.0">
                                 <children>
                                    <AnchorPane styleClass="profile-avatar-container">
                                       <children>
                                          <Circle fx:id="imageClip" fill="WHITE" layoutX="70.0" layoutY="70.0" radius="70.0" />
                                          <ImageView fx:id="profileImage" fitHeight="140.0" fitWidth="140.0" pickOnBounds="true" preserveRatio="true" />
                                       </children>
                                    </AnchorPane>
                                    <Button mnemonicParsing="false" onAction="#uploadPhotoAction" styleClass="btn-white-sm" text="Change Photo" />
                                 </children>
                              </VBox>
                              <VBox alignment="CENTER_LEFT" spacing="8.0">
                                 <children>
                                    <Label fx:id="nameLabel" styleClass="banner-title" text="User Full Name" />
                                    <Label fx:id="roleLabel" styleClass="banner-subtitle" text="Professional Role" />
                                    <HBox spacing="10.0">
                                       <children>
                                          <Region prefWidth="5.0" />
                                          <Label fx:id="usernameVal" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-weight: bold;" text="@username" />
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
      
                  <!-- Edit Details Section -->
                  <VBox layoutX="50.0" layoutY="250.0" prefWidth="750.0" spacing="25.0">
                     <children>
                        <Text style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-fill: #1e293b;" text="Personal Information" />
                        
                        <GridPane hgap="25.0" vgap="20.0">
                           <columnConstraints>
                              <ColumnConstraints prefWidth="350.0" />
                              <ColumnConstraints prefWidth="350.0" />
                           </columnConstraints>
                           <children>
                              <!-- First Name -->
                              <VBox spacing="5.0" styleClass="profile-info-group" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                 <children>
                                    <Label styleClass="profile-field-label" text="FIRST NAME" />
                                    <TextField fx:id="firstNameField" promptText="Enter first name" styleClass="transparent-input" />
                                 </children>
                              </VBox>
                              <!-- Last Name -->
                              <VBox spacing="5.0" styleClass="profile-info-group" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                 <children>
                                    <Label styleClass="profile-field-label" text="LAST NAME" />
                                    <TextField fx:id="lastNameField" promptText="Enter last name" styleClass="transparent-input" />
                                 </children>
                              </VBox>
                              <!-- Email -->
                              <VBox spacing="5.0" styleClass="profile-info-group" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                 <children>
                                    <Label styleClass="profile-field-label" text="EMAIL ADDRESS" />
                                    <TextField fx:id="emailField" promptText="Enter email" styleClass="transparent-input" />
                                 </children>
                              </VBox>
                              <!-- Phone -->
                              <VBox spacing="5.0" styleClass="profile-info-group" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                 <children>
                                    <Label styleClass="profile-field-label" text="PHONE NUMBER" />
                                    <TextField fx:id="phoneField" promptText="Enter phone" styleClass="transparent-input" />
                                 </children>
                              </VBox>
                              <!-- Gender -->
                              <VBox spacing="5.0" styleClass="profile-info-group" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                 <children>
                                    <Label styleClass="profile-field-label" text="GENDER" />
                                    <ComboBox fx:id="genderBox" prefWidth="Infinity" styleClass="transparent-input">
                                       <items>
                                          <FXCollections fx:factory="observableArrayList">
                                             <String fx:value="Male" />
                                             <String fx:value="Female" />
                                          </FXCollections>
                                       </items>
                                    </ComboBox>
                                 </children>
                              </VBox>
                              <!-- Role -->
                              <VBox spacing="5.0" styleClass="profile-info-group" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                 <children>
                                    <Label styleClass="profile-field-label" text="PROFESSIONAL ROLE" />
                                    <ComboBox fx:id="roleBox" prefWidth="Infinity" styleClass="transparent-input">
                                       <items>
                                          <FXCollections fx:factory="observableArrayList">
                                             <String fx:value="Doctor" />
                                             <String fx:value="Stagiaire" />
                                             <String fx:value="Secretaire" />
                                          </FXCollections>
                                       </items>
                                    </ComboBox>
                                 </children>
                              </VBox>
                           </children>
                        </GridPane>

                        <HBox alignment="CENTER_RIGHT" spacing="15.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#deleteAccountAction" styleClass="btn-delete-account" text="Delete Account" />
                              <Region HBox.hgrow="ALWAYS" />
                               <Button mnemonicParsing="false" onAction="#backToDashboard" prefHeight="45.0" prefWidth="140.0" styleClass="btn-go-back" text="Go Back" />
                              <Button mnemonicParsing="false" onAction="#saveChangesAction" prefHeight="45.0" prefWidth="180.0" styleClass="btn-save-changes" text="Save Changes" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </AnchorPane>
         </children>
      </StackPane>

      <!-- Window Controls (Must be last to be on top) -->
      <HBox alignment="TOP_RIGHT" spacing="8.0" styleClass="win-control-box" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleMinimize" styleClass="win-btn, win-btn-min" text="—" />
            <Button mnemonicParsing="false" onAction="#handleMaximize" styleClass="win-btn, win-btn-max" text="□" />
            <Button mnemonicParsing="false" onAction="#handleClose" styleClass="win-btn, win-btn-close" text="✕" />
         </children>
      </HBox>
   </children>
</AnchorPane>
