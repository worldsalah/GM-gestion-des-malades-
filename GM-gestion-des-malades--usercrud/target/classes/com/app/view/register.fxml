<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Group?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<AnchorPane fx:id="rootPane" onMouseDragged="#onWindowDragged" onMousePressed="#onWindowPressed" prefHeight="750.0" prefWidth="1000.0" styleClass="main-app-pane" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.app.controller.RegisterController">
   <children>
      <!-- Centering Container -->
      <javafx.scene.layout.StackPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="600.0" prefWidth="800.0">
               <children>
                  <!-- Layer 1: The shadow base for the card -->
                  <AnchorPane prefHeight="600.0" prefWidth="800.0" styleClass="card-shadow" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
            
                  <!-- Layer 2: The actual card -->
                  <AnchorPane prefHeight="600.0" prefWidth="800.0" styleClass="card-pane" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                     <clip>
                        <Rectangle arcHeight="30.0" arcWidth="30.0" height="600.0" width="800.0" />
                     </clip>
                     
                     <children>
                        <!-- Left Side Decorations (Capsules from Image) -->
                        <Group>
                           <Rectangle arcHeight="100.0" arcWidth="100.0" height="550.0" layoutX="120.0" layoutY="-250.0" rotate="-25.0" styleClass="shape-purple" width="120.0" />
                           <Rectangle arcHeight="60.0" arcWidth="60.0" height="180.0" layoutX="-40.0" layoutY="150.0" styleClass="shape-pink" width="70.0" />
                           <Rectangle arcHeight="100.0" arcWidth="100.0" height="400.0" layoutX="-80.0" layoutY="400.0" rotate="-55.0" styleClass="shape-blue-violet" width="100.0" />
                        </Group>
            
                        <!-- Registration Form Area -->
                        <VBox alignment="CENTER" layoutX="320.0" prefHeight="600.0" prefWidth="480.0" spacing="12.0">
                           <padding>
                               <Insets bottom="20.0" left="40.0" right="40.0" top="20.0" />
                           </padding>
                           <children>
                              <Region VBox.vgrow="ALWAYS" />
                              <Text styleClass="login-header" text="Join UniLearn" />
                              <Text styleClass="tiny-label" text="Get started with your free account" />
                              
                              <Region prefHeight="10.0" />
                              
                              <!-- Responsive 2-column Grid for inputs -->
                              <GridPane hgap="12.0" vgap="12.0">
                                <columnConstraints>
                                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                </columnConstraints>
                                <rowConstraints>
                                  <RowConstraints minHeight="10.0" prefHeight="45.0" vgrow="SOMETIMES" />
                                  <RowConstraints minHeight="10.0" prefHeight="45.0" vgrow="SOMETIMES" />
                                  <RowConstraints minHeight="10.0" prefHeight="45.0" vgrow="SOMETIMES" />
                                  <RowConstraints minHeight="10.0" prefHeight="45.0" vgrow="SOMETIMES" />
                                </rowConstraints>
                                <children>
                                    <!-- First Name -->
                                    <HBox alignment="CENTER_LEFT" styleClass="input-group" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                       <children>
                                          <TextField fx:id="firstNameField" promptText="First Name" styleClass="transparent-input" HBox.hgrow="ALWAYS" />
                                       </children>
                                    </HBox>
                                    
                                    <!-- Last Name -->
                                    <HBox alignment="CENTER_LEFT" styleClass="input-group" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                       <children>
                                          <TextField fx:id="lastNameField" promptText="Last Name" styleClass="transparent-input" HBox.hgrow="ALWAYS" />
                                       </children>
                                    </HBox>
                                    
                                    <!-- Email -->
                                    <HBox alignment="CENTER_LEFT" styleClass="input-group" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="1">
                                       <children>
                                          <TextField fx:id="emailField" promptText="Email Address" styleClass="transparent-input" HBox.hgrow="ALWAYS" />
                                       </children>
                                    </HBox>
                                    
                                    <!-- Phone -->
                                    <HBox alignment="CENTER_LEFT" styleClass="input-group" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                       <children>
                                          <TextField fx:id="phoneField" promptText="Phone Number" styleClass="transparent-input" HBox.hgrow="ALWAYS" />
                                       </children>
                                    </HBox>
                                    
                                    <!-- Gender -->
                                    <HBox alignment="CENTER_LEFT" styleClass="input-group" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                       <children>
                                          <ComboBox fx:id="genderBox" prefWidth="Infinity" promptText="Gender" styleClass="transparent-input" HBox.hgrow="ALWAYS">
                                             <items>
                                                <FXCollections fx:factory="observableArrayList">
                                                   <String fx:value="Male" />
                                                   <String fx:value="Female" />
                                                </FXCollections>
                                             </items>
                                          </ComboBox>
                                       </children>
                                    </HBox>
             
                                    <!-- Role -->
                                    <HBox alignment="CENTER_LEFT" styleClass="input-group" GridPane.columnIndex="0" GridPane.rowIndex="3">
                                       <children>
                                           <ComboBox fx:id="roleBox" prefWidth="Infinity" promptText="Professional Role" styleClass="transparent-input" HBox.hgrow="ALWAYS">
                                             <items>
                                                <FXCollections fx:factory="observableArrayList">
                                                   <String fx:value="Doctor" />
                                                   <String fx:value="Stagiaire" />
                                                   <String fx:value="Secretaire" />
                                                </FXCollections>
                                             </items>
                                          </ComboBox>
                                       </children>
                                    </HBox>
             
                                    <!-- Username -->
                                    <HBox alignment="CENTER_LEFT" styleClass="input-group" GridPane.columnIndex="1" GridPane.rowIndex="3">
                                       <children>
                                          <TextField fx:id="usernameField" promptText="Username" styleClass="transparent-input" HBox.hgrow="ALWAYS" />
                                       </children>
                                    </HBox>
                                </children>
                              </GridPane>
                              
                              <HBox alignment="CENTER_LEFT" prefHeight="45.0" styleClass="input-group">
                                 <children>
                                    <PasswordField fx:id="passwordField" promptText="Set a Strong Password" styleClass="transparent-input" HBox.hgrow="ALWAYS" />
                                 </children>
                              </HBox>
             
                              <Label fx:id="messageLabel" textFill="#ff4757" wrapText="true" />
                              
                              <Button mnemonicParsing="false" onAction="#registerAction" prefHeight="45.0" prefWidth="Infinity" styleClass="btn-login" text="COMPLETE REGISTRATION" />
                              
                              <HBox alignment="CENTER" spacing="5.0">
                                 <children>
                                    <Text styleClass="tiny-label" text="Already have an account?" />
                                    <Text onMouseClicked="#backToLogin" styleClass="link-text" text="Login here" />
                                 </children>
                              </HBox>
                              <Region VBox.vgrow="ALWAYS" />
                           </children>
                        </VBox>
                     </children>
                  </AnchorPane>
               </children>
            </AnchorPane>
         </children>
      </javafx.scene.layout.StackPane>

      <!-- Window Controls (Must be last to be on top) -->
      <HBox alignment="TOP_RIGHT" spacing="8.0" styleClass="win-control-box" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleMinimize" styleClass="win-btn, win-btn-min" text="—" />
            <Button mnemonicParsing="false" onAction="#handleMaximize" styleClass="win-btn, win-btn-max" text="□" />
            <Button mnemonicParsing="false" onAction="#handleClose" styleClass="win-btn, win-btn-close" text="✕" />
         </children>
      </HBox>
   </children>
</AnchorPane>
