<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<AnchorPane fx:id="rootPane"
            onMouseDragged="#onWindowDragged"
            onMousePressed="#onWindowPressed"
            prefHeight="900.0" prefWidth="1400.0"
            styleClass="dashboard-container"
            stylesheets="@../css/style.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.app.controller.AppointmentController">
  <children>
    <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

      <!-- ══════════════════════════ SIDEBAR ══════════════════════════ -->
      <left>
        <VBox prefWidth="250.0" styleClass="sidebar">
          <children>
            <Label styleClass="sidebar-logo" text="Doctor App">
              <VBox.margin><Insets bottom="50.0" left="25.0" right="25.0" top="30.0"/></VBox.margin>
            </Label>

            <VBox spacing="10.0" VBox.vgrow="ALWAYS">
              <padding><Insets left="20.0" right="20.0"/></padding>
              <children>
                <HBox alignment="CENTER_LEFT" onMouseClicked="#goToDashboard" styleClass="menu-item">
                  <children>
                    <SVGPath content="M3,13h8V3H3V13z M3,21h8v-6H3V21z M13,21h8V11h-8V21z M13,3v6h8V3H13z" fill="#b8c2d1"/>
                    <Label text="Dashboard"/>
                  </children>
                </HBox>
                <HBox alignment="CENTER_LEFT" onMouseClicked="#goToPatients" styleClass="menu-item">
                  <children>
                    <SVGPath content="M12,12c2.21,0,4-1.79,4-4s-1.79-4-4-4s-4,1.79-4,4S9.79,12,12,12z M12,14c-2.67,0-8,1.34-8,4v2h16v-2C20,15.34,14.67,14,12,14z" fill="#b8c2d1"/>
                    <Label text="Patients"/>
                  </children>
                </HBox>
                <HBox alignment="CENTER_LEFT" styleClass="menu-item, active-menu-item">
                  <children>
                    <SVGPath content="M19,3h-1V1h-2v2H8V1H6v2H5C3.89,3,3,3.9,3,5v14c0,1.1,0.89,2,2,2h14c1.1,0,2-0.9,2-2V5C21,3.9,20.11,3,19,3z M19,19H5V8h14V19z" fill="WHITE"/>
                    <Label text="Appointment"/>
                  </children>
                </HBox>
                <HBox alignment="CENTER_LEFT" onMouseClicked="#openTasksPage" styleClass="menu-item">
                  <children>
                    <SVGPath content="M19,3H14.82C14.4,1.84,13.3,1,12,1S9.6,1.84,9.18,3H5C3.9,3,3,3.9,3,5v14c0,1.1,0.9,2,2,2h14c1.1,0,2-0.9,2-2V5C21,3.9,20.1,3,19,3z M12,3c0.55,0,1,0.45,1,1s-0.45,1-1,1s-1-0.45-1-1S11.45,3,12,3z M10,17l-4-4l1.41-1.41L10,14.17l6.59-6.59L18,9L10,17z" fill="#b8c2d1" />
                    <Label text="Tasks" />
                  </children>
                </HBox>
                <HBox alignment="CENTER_LEFT" onMouseClicked="#openProfilePage" styleClass="menu-item">
                  <children>
                    <SVGPath content="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M12,5c1.66,0,3,1.34,3,3s-1.34,3-3,3 s-3-1.34-3-3S10.34,5,12,5z M12,19.2c-2.5,0-4.71-1.28-6-3.22c0.03-1.99,4-3.08,6-3.08s5.97,1.09,6,3.08 C16.71,17.92,14.5,19.2,12,19.2z" fill="#b8c2d1"/>
                    <Label text="My Profile"/>
                  </children>
                </HBox>
              </children>
            </VBox>

            <HBox alignment="CENTER_LEFT" onMouseClicked="#logoutAction" styleClass="menu-item, logout-item">
              <children>
                <SVGPath content="M17,7l-1.41,1.41L18.17,11H8v2h10.17l-2.58,2.58L17,17l5-5L17,7z M4,5h8V3H4C2.9,3,2,3.9,2,5v14c0,1.1,0.9,2,2,2h8v-2H4V5z" fill="#b8c2d1"/>
                <Label text="Logout"/>
              </children>
              <VBox.margin><Insets bottom="30.0" left="20.0" right="20.0"/></VBox.margin>
            </HBox>
          </children>
        </VBox>
      </left>

      <!-- ══════════════════════════ MAIN CONTENT ══════════════════════════ -->
      <center>
        <VBox styleClass="main-content">
          <children>

            <!-- TOP NAV -->
            <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" styleClass="top-nav">
              <children>
                <Label styleClass="appt-page-title" text="📅  Appointment Calendar"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button onAction="#showNewAppointmentForm" styleClass="btn-primary" text="＋  New Appointment"/>
              </children>
              <padding><Insets left="30.0" right="30.0"/></padding>
            </HBox>

            <!-- TWO-COLUMN LAYOUT -->
            <HBox spacing="0.0" VBox.vgrow="ALWAYS">
              <children>

                <!-- ─── LEFT: Calendar ─── -->
                <VBox prefWidth="820.0" spacing="0.0" styleClass="cal-container" HBox.hgrow="ALWAYS">
                  <children>

                    <!-- Calendar Header: nav + month label -->
                    <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="cal-header">
                      <children>
                        <Button onAction="#prevMonth" styleClass="cal-nav-btn" text="‹"/>
                        <Label fx:id="monthYearLabel" styleClass="cal-month-label" text="March 2026"/>
                        <Button onAction="#nextMonth" styleClass="cal-nav-btn" text="›"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button onAction="#goToday" styleClass="btn-today" text="Today"/>
                      </children>
                      <padding><Insets bottom="20.0" left="30.0" right="30.0" top="20.0"/></padding>
                    </HBox>

                    <!-- Day-of-week headers -->
                    <GridPane styleClass="cal-dow-row" maxWidth="Infinity">
                      <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28"/>
                      </columnConstraints>
                      <children>
                        <Label text="Mon" styleClass="cal-dow" GridPane.columnIndex="0"/>
                        <Label text="Tue" styleClass="cal-dow" GridPane.columnIndex="1"/>
                        <Label text="Wed" styleClass="cal-dow" GridPane.columnIndex="2"/>
                        <Label text="Thu" styleClass="cal-dow" GridPane.columnIndex="3"/>
                        <Label text="Fri" styleClass="cal-dow" GridPane.columnIndex="4"/>
                        <Label text="Sat" styleClass="cal-dow" GridPane.columnIndex="5"/>
                        <Label text="Sun" styleClass="cal-dow" GridPane.columnIndex="6"/>
                      </children>
                    </GridPane>

                    <!-- The dynamic calendar grid (cells added by controller) -->
                    <ScrollPane fitToWidth="true" fitToHeight="false" VBox.vgrow="ALWAYS"
                                styleClass="cal-scroll" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
                      <content>
                        <GridPane fx:id="calendarGrid" styleClass="cal-grid"
                                  gridLinesVisible="true" maxWidth="Infinity">
                          <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28" minWidth="100"/>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28" minWidth="100"/>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28" minWidth="100"/>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28" minWidth="100"/>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28" minWidth="100"/>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28" minWidth="100"/>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28" minWidth="100"/>
                          </columnConstraints>
                          <!-- Row 0 is always empty / placeholder header (kept for GridPane RowIndex alignment) -->
                          <rowConstraints>
                            <RowConstraints minHeight="0" prefHeight="0" maxHeight="0"/>
                          </rowConstraints>
                        </GridPane>
                      </content>
                    </ScrollPane>
                  </children>
                </VBox>

                <!-- ─── RIGHT: Day Appointments Panel / Form ─── -->
                <VBox prefWidth="380.0" styleClass="appt-right-panel">
                  <children>

                    <!-- Appointment List Panel -->
                    <VBox fx:id="appointmentListPanel" spacing="0.0" VBox.vgrow="ALWAYS">
                      <children>
                        <VBox styleClass="day-panel-header" spacing="4.0">
                          <padding><Insets bottom="18.0" left="20.0" right="20.0" top="20.0"/></padding>
                          <children>
                            <Label fx:id="selectedDayLabel" styleClass="day-panel-date" text="Monday, March 2 2026"/>
                            <Label styleClass="dim-label" text="Scheduled appointments for this day"/>
                          </children>
                        </VBox>

                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                    styleClass="content-scroll" hbarPolicy="NEVER">
                          <content>
                            <VBox fx:id="dayAppointmentsList" spacing="10.0">
                              <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0"/></padding>
                            </VBox>
                          </content>
                        </ScrollPane>
                      </children>
                    </VBox>

                    <!-- Appointment Form Panel (initially hidden) -->
                    <VBox fx:id="appointmentFormPanel" spacing="0.0" VBox.vgrow="ALWAYS" visible="false" managed="false">
                      <children>
                        <VBox styleClass="day-panel-header" spacing="4.0">
                          <padding><Insets bottom="18.0" left="20.0" right="20.0" top="20.0"/></padding>
                          <children>
                            <Label fx:id="formTitleLabel" styleClass="day-panel-date" text="New Appointment"/>
                            <Label styleClass="dim-label" text="Fill in the details below"/>
                          </children>
                        </VBox>

                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                    styleClass="content-scroll" hbarPolicy="NEVER">
                          <content>
                            <VBox spacing="14.0">
                              <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0"/></padding>
                              <children>

                                <VBox spacing="5.0">
                                  <Label styleClass="form-field-label" text="Patient *"/>
                                  <ComboBox fx:id="patientCombo" promptText="Select patient" maxWidth="Infinity"/>
                                </VBox>

                                <VBox spacing="5.0">
                                  <Label styleClass="form-field-label" text="Date *"/>
                                  <DatePicker fx:id="appointmentDatePicker" maxWidth="Infinity"/>
                                </VBox>

                                <VBox spacing="5.0">
                                  <Label styleClass="form-field-label" text="Time *"/>
                                  <ComboBox fx:id="timePicker" promptText="Select time" maxWidth="Infinity"/>
                                </VBox>

                                <VBox spacing="5.0">
                                  <Label styleClass="form-field-label" text="Reason"/>
                                  <TextField fx:id="reasonField" promptText="E.g. Annual checkup, Flu symptoms…"/>
                                </VBox>

                                <VBox spacing="5.0">
                                  <Label styleClass="form-field-label" text="Status"/>
                                  <ComboBox fx:id="statusCombo" maxWidth="Infinity"/>
                                </VBox>

                                <VBox spacing="5.0">
                                  <Label styleClass="form-field-label" text="Notes"/>
                                  <TextArea fx:id="notesArea" prefHeight="80.0" wrapText="true"
                                            promptText="Additional notes…"/>
                                </VBox>

                                <HBox spacing="10.0">
                                  <children>
                                    <Button fx:id="saveBtn" onAction="#saveAppointment"
                                            styleClass="btn-primary" text="Save Appointment"
                                            HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                    <Button onAction="#cancelForm" styleClass="btn-secondary"
                                            text="Cancel" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                  </children>
                                </HBox>

                              </children>
                            </VBox>
                          </content>
                        </ScrollPane>
                      </children>
                    </VBox>
                  </children>
                </VBox>

              </children>
            </HBox>
          </children>
        </VBox>
      </center>
    </BorderPane>

    <!-- Window Controls -->
    <HBox alignment="TOP_RIGHT" spacing="8.0" styleClass="win-control-box"
          AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
      <children>
        <Button mnemonicParsing="false" onAction="#handleMinimize" styleClass="win-btn, win-btn-min" text="—"/>
        <Button mnemonicParsing="false" onAction="#handleMaximize" styleClass="win-btn, win-btn-max" text="□"/>
        <Button mnemonicParsing="false" onAction="#handleClose" styleClass="win-btn, win-btn-close" text="✕"/>
      </children>
    </HBox>
  </children>
</AnchorPane>
