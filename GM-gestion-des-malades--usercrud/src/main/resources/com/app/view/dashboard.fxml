                        <VBox fx:id="sidebarMenu" spacing="10.0" VBox.vgrow="ALWAYS">
                            <padding>
                                <Insets left="20.0" right="20.0" />
                            </padding>
                            <children>
                                <HBox alignment="CENTER_LEFT" styleClass="menu-item, active-menu-item">
                                    <children>
                                        <SVGPath content="M3,13h8V3H3V13z M3,21h8v-6H3V21z M13,21h8V11h-8V21z M13,3v6h8V3H13z" fill="WHITE" />
                                        <Label text="Dashboard" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" onMouseClicked="#openPatientsPage" styleClass="menu-item">
                                    <children>
                                        <SVGPath content="M12,12c2.21,0,4-1.79,4-4s-1.79-4-4-4s-4,1.79-4,4S9.79,12,12,12z M12,14c-2.67,0-8,1.34-8,4v2h16v-2C20,15.34,14.67,14,12,14z" fill="#b8c2d1" />
                                        <Label text="Patients" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" onMouseClicked="#openAppointmentsPage" styleClass="menu-item">
                                    <children>
                                        <SVGPath content="M19,3h-1V1h-2v2H8V1H6v2H5C3.89,3,3,3.9,3,5v14c0,1.1,0.89,2,2,2h14c1.1,0,2-0.9,2-2V5C21,3.9,20.11,3,19,3z M19,19H5V8h14V19z" fill="#b8c2d1" />
                                        <Label text="Appointment" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" onMouseClicked="#openTasksPage" styleClass="menu-item">
