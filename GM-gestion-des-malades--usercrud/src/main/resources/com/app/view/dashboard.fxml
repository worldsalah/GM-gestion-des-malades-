                                        <Label text="Tasks" />
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" styleClass="menu-item">
                                    <children>
                                        <SVGPath content="M11.8,2.1L3,5.1V11c0,5.5,3.8,10.7,8.8,12c5-1.3,8.8-6.5,8.8-12V5.1L11.8,2.1z M17,11c0,4.5-2.9,8.7-7,9.9V4.2l7,2.4V11z" fill="#b8c2d1" />
                                        <Label text="Finances" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" onMouseClicked="#openProfilePage" styleClass="menu-item">
                                    <children>
                                        <SVGPath content="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M12,5c1.66,0,3,1.34,3,3s-1.34,3-3,3 s-3-1.34-3-3S10.34,5,12,5z M12,19.2c-2.5,0-4.71-1.28-6-3.22c0.03-1.99,4-3.08,6-3.08s5.97,1.09,6,3.08 C16.71,17.92,14.5,19.2,12,19.2z" fill="#b8c2d1" />
                                        <Label text="My Profile" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" styleClass="menu-item">
                                    <children>
                                        <SVGPath content="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.06-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.73,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.06,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.43-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.49-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" fill="#b8c2d1" />
                                        <Label text="Settings" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        
                        <HBox alignment="CENTER_LEFT" onMouseClicked="#logoutAction" styleClass="menu-item, logout-item">
                            <children>
                                <SVGPath content="M17,7l-1.41,1.41L18.17,11H8v2h10.17l-2.58,2.58L17,17l5-5L17,7z M4,5h8V3H4C2.9,3,2,3.9,2,5v14c0,1.1,0.9,2,2,2h8v-2H4V5z" fill="#b8c2d1" />
                                <Label text="Logout" />
                            </children>
                            <VBox.margin>
                                <Insets bottom="30.0" left="20.0" right="20.0" />
                            </VBox.margin>
                        </HBox>
                    </children>
                </VBox>
            </left>
            
            <!-- Center Main Content -->
            <center>
                <VBox styleClass="main-content">
                    <children>
                        <!-- Top Nav / Search bar -->
                        <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="20.0" styleClass="top-nav">
                            <children>
                                <HBox alignment="CENTER_LEFT" styleClass="search-box" HBox.hgrow="ALWAYS">
                                    <children>
                                        <SVGPath content="M15.5,14h-0.79l-0.28-0.27C15.41,12.59,16,11.11,16,9.5C16,5.91,13.09,3,9.5,3S3,5.91,3,9.5S5.91,16,9.5,16 c1.61,0,3.09-0.59,4.23-1.57l0.27,0.28v0.79l5,4.99L20.49,19L15.5,14z M9.5,14C7.01,14,5,11.99,5,9.5S7.01,5,9.5,5S14,7.01,14,9.5 S11.99,14,9.5,14z" fill="#7f8fa6" />
                                        <TextField promptText="Search Anything..." styleClass="search-input" HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER" spacing="25.0">
                                    <children>
                                        <SVGPath content="M12,22c1.1,0,2-0.9,2-2h-4C10,21.1,10.9,22,12,22z M18,16v-5c0-3.07-1.63-5.64-4.5-6.32V4c0-0.83-0.67-1.5-1.5-1.5 s-1.5,0.67-1.5,1.5v0.68C7.64,5.36,6,7.92,6,11v5l-2,2v1h16v-1L18,16z" fill="#7f8fa6" />
                                        <Button onAction="#openAppointmentsPage" styleClass="btn-primary" text="+ Make Appointment" />
                                    </children>
                                </HBox>
                            </children>
                            <padding>
                                <Insets left="30.0" right="30.0" />
                            </padding>
                        </HBox>
                        
                        <ScrollPane fitToWidth="true" styleClass="content-scroll" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox spacing="30.0" styleClass="content-area">
                                    <padding>
                                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                                    </padding>
                                    <children>
                                        
                                        <!-- Essential Cards Row -->
                                        <HBox spacing="20.0">
                                            <children>
                                                <!-- Total Patients -->
                                                <VBox styleClass="card, dash-card" spacing="10.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                                                            <children>
                                                                <StackPane styleClass="icon-bg, bg-blue-light">
                                                                    <children>
                                                                        <SVGPath content="M12,12c2.2,0,4-1.8,4-4s-1.8-4-4-4s-4,1.8-4,4S9.8,12,12,12z M12,14c-2.7,0-8,1.3-8,4v2h16v-2C20,15.3,14.7,14,12,14z" fill="#5352ed" />
                                                                    </children>
                                                                </StackPane>
                                                                <VBox HBox.hgrow="ALWAYS">
                                                                    <children>
                                                                        <Label text="Total Patients" styleClass="card-subtitle" />
                                                                        <Label fx:id="totalPatientsLabel" text="0" styleClass="card-value" />
                                                                    </children>
                                                                </VBox>
                                                            </children>
                                                        </HBox>
                                                        <Label text="Active records in system" styleClass="card-desc" />
                                                    </children>
                                                </VBox>
                                                
                                                <!-- Today's Appointments -->
                                                <VBox styleClass="card, dash-card" spacing="10.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                                                            <children>
                                                                <StackPane styleClass="icon-bg, bg-purple-light">
                                                                    <children>
                                                                        <SVGPath content="M19,3h-1V1h-2v2H8V1H6v2H5C3.9,3,3,3.9,3,5v14c0,1.1,0.9,2,2,2h14c1.1,0,2-0.9,2-2V5C21,3.9,20.1,3,19,3z M19,19H5V8h14V19z" fill="#7c3aed" />
                                                                    </children>
                                                                </StackPane>
                                                                <VBox HBox.hgrow="ALWAYS">
                                                                    <children>
                                                                        <Label text="Today Appts" styleClass="card-subtitle" />
                                                                        <Label fx:id="todayApptsLabel" text="0" styleClass="card-value" />
                                                                    </children>
                                                                </VBox>
                                                            </children>
                                                        </HBox>
                                                        <Label text="Scheduled for today" styleClass="card-desc" />
                                                    </children>
                                                </VBox>

                                                <!-- Today's Revenue -->
                                                <VBox styleClass="card, dash-card" spacing="10.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                                                            <children>
                                                                <StackPane styleClass="icon-bg, bg-green-light">
                                                                    <children>
                                                                        <SVGPath content="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M12.5,17h-1v-1.1c-1.39-0.23-2.28-1.35-2.28-2.54h1.5 c0,0.86,0.59,1.52,1.69,1.52c1.14,0,1.59-0.65,1.59-1.22c0-0.78-0.69-1.1-1.78-1.42c-1.63-0.47-2.61-1.24-2.61-2.48 c0-1.1,0.87-2.05,2.08-2.33V6h1v1.17c1.13,0.22,1.96,1.14,2.04,2.18h-1.5c-0.09-0.56-0.56-1.12-1.48-1.12 c-0.91,0-1.41,0.55-1.41,1.11c0,0.73,0.61,1.01,1.87,1.38c1.65,0.48,2.52,1.26,2.52,2.52C14.75,15.82,13.88,16.73,12.5,17z" fill="#10b981" />
                                                                    </children>
                                                                </StackPane>
                                                                <VBox HBox.hgrow="ALWAYS">
                                                                    <children>
                                                                        <Label text="Today's Revenue" styleClass="card-subtitle" />
                                                                        <HBox alignment="CENTER_LEFT" spacing="2.0">
                                                                           <children>
                                                                               <Label text="\$" styleClass="card-value" />
                                                                               <Label fx:id="todayRevenueLabel" text="0" styleClass="card-value" />
                                                                           </children>
                                                                        </HBox>
                                                                    </children>
                                                                </VBox>
                                                            </children>
                                                        </HBox>
                                                        <Label text="Earned today" styleClass="card-desc" />
                                                    </children>
                                                </VBox>

                                                <!-- Treatments This Month -->
                                                <VBox styleClass="card, dash-card" spacing="10.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                                                            <children>
                                                                <StackPane styleClass="icon-bg, bg-pink-light">
                                                                    <children>
                                                                        <SVGPath content="M19,3H5C3.9,3,3,3.9,3,5v14c0,1.1,0.9,2,2,2h14c1.1,0,2-0.9,2-2V5C21,3.9,20.1,3,19,3z M17,13h-4v4h-2v-4H7v-2h4V7h2v4h4V13z" fill="#f43f5e" />
                                                                    </children>
                                                                </StackPane>
                                                                <VBox HBox.hgrow="ALWAYS">
                                                                    <children>
                                                                        <Label text="Treatments/Mo" styleClass="card-subtitle" />
                                                                        <Label fx:id="treatmentsMonthLabel" text="0" styleClass="card-value" />
                                                                    </children>
                                                                </VBox>
                                                            </children>
                                                        </HBox>
                                                        <Label text="Performed this month" styleClass="card-desc" />
                                                    </children>
                                                </VBox>

                                                <!-- Pending Payments -->
                                                <VBox styleClass="card, dash-card" spacing="10.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                                                            <children>
                                                                <StackPane styleClass="icon-bg, bg-orange-light">
                                                                    <children>
                                                                        <SVGPath content="M11.99,2C6.47,2,2,6.48,2,12s4.47,10,9.99,10C17.52,22,22,17.52,22,12S17.52,2,11.99,2z M12,20c-4.42,0-8-3.58-8-8s3.58-8,8-8s8,3.58,8,8S16.42,20,12,20z M11,7H12.5V12.25L17,14.92L16.25,16.15L11,13V7Z" fill="#f59e0b" />
                                                                    </children>
                                                                </StackPane>
                                                                <VBox HBox.hgrow="ALWAYS">
                                                                    <children>
                                                                        <Label text="Pending Payments" styleClass="card-subtitle" />
                                                                        <Label fx:id="pendingPaymentsLabel" text="0" styleClass="card-value" />
                                                                    </children>
                                                                </VBox>
                                                            </children>
                                                        </HBox>
                                                        <Label text="Awaiting collection" styleClass="card-desc" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>

                                        <!-- Two Column Split (Schedule + Analytics) -->
                                        <HBox spacing="30.0">
                                            <children>
                                                <!-- Left Column -->
                                                <VBox spacing="30.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <!-- Today's Schedule Panel -->
                                                        <VBox styleClass="card" spacing="20.0" VBox.vgrow="ALWAYS" minHeight="350">
                                                            <children>
                                                                <Label text="Today's Schedule" styleClass="section-title-large" />
                                                                <TableView fx:id="scheduleTable" VBox.vgrow="ALWAYS" styleClass="custom-table-view">
                                                                    <columns>
                                                                        <TableColumn fx:id="colTime" text="Time" prefWidth="80" />
                                                                        <TableColumn fx:id="colPatient" text="Patient Name" prefWidth="180" />
                                                                        <TableColumn fx:id="colTreatment" text="Treatment" prefWidth="150" />
                                                                        <TableColumn fx:id="colStatus" text="Status" prefWidth="120" />
                                                                        <TableColumn fx:id="colAction" text="Action" prefWidth="100" />
                                                                    </columns>
                                                                </TableView>
                                                            </children>
                                                        </VBox>
                                                        
                                                        <!-- Recent Patient Activity -->
                                                        <VBox styleClass="card" spacing="20.0">
                                                            <children>
                                                                <Label text="Recent Patient Activity" styleClass="section-title-large" />
                                                                <VBox fx:id="recentActivityContainer" spacing="15.0">
                                                                    <!-- Inside the controller, we will inject HBox items here -->
                                                                </VBox>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </VBox>
                                                
                                                <!-- Right Column -->
                                                <VBox spacing="30.0" prefWidth="450.0" minWidth="450.0">
                                                    <children>
                                                        <!-- Monthly Revenue -->
                                                        <VBox styleClass="card" alignment="CENTER" spacing="15.0">
                                                            <children>
                                                                <Label text="Monthly Revenue" styleClass="section-title-large" alignment="TOP_LEFT" maxWidth="Infinity" />
                                                                <BarChart fx:id="monthlyRevenueChart" prefHeight="250.0" legendVisible="false">
                                                                    <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                                                                    <yAxis><NumberAxis side="LEFT" /></yAxis>
                                                                </BarChart>
                                                            </children>
                                                        </VBox>
                                                        
                                                        <!-- Revenue by Treatment -->
                                                        <VBox styleClass="card" alignment="CENTER" spacing="15.0">
                                                            <children>
                                                                <Label text="Revenue by Treatment" styleClass="section-title-large" alignment="TOP_LEFT" maxWidth="Infinity" />
                                                                <BarChart fx:id="treatmentRevenueChart" prefHeight="250.0" legendVisible="false">
                                                                    <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                                                                    <yAxis><NumberAxis side="LEFT" /></yAxis>
                                                                </BarChart>
                                                            </children>
                                                        </VBox>
                                                        
                                                        <!-- Payment Status -->
                                                        <VBox styleClass="card" alignment="CENTER" spacing="15.0">
                                                            <children>
                                                                <Label text="Payment Status" styleClass="section-title-large" alignment="TOP_LEFT" maxWidth="Infinity" />
                                                                <PieChart fx:id="paymentStatusChart" prefHeight="250.0" />
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                        
                                    </children>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>
            </center>
        </BorderPane>

        <!-- Window Controls -->
        <HBox alignment="TOP_RIGHT" spacing="8.0" styleClass="win-control-box" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Button mnemonicParsing="false" onAction="#handleMinimize" styleClass="win-btn, win-btn-min" text="—" />
                <Button mnemonicParsing="false" onAction="#handleMaximize" styleClass="win-btn, win-btn-max" text="□" />
                <Button mnemonicParsing="false" onAction="#handleClose" styleClass="win-btn, win-btn-close" text="✕" />
            </children>
        </HBox>
    </children>
</AnchorPane>
