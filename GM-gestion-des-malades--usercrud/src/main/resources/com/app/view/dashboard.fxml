<?import javafx.scene.text.Font?>

<AnchorPane fx:id="rootPane" onMouseDragged="#onWindowDragged" onMousePressed="#onWindowPressed" prefHeight="900.0" prefWidth="1400.0" styleClass="dashboard-container" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.app.controller.DashboardController">
