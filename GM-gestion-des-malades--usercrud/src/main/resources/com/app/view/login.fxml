<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Group?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane fx:id="rootPane" onMouseDragged="#onWindowDragged" onMousePressed="#onWindowPressed" prefHeight="600.0" prefWidth="900.0" styleClass="main-app-pane" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.app.controller.LoginController">
   <children>
      <!-- Centering Container -->
      <StackPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="450.0" prefWidth="700.0">
               <children>
                  <!-- Layer 1: The shadow base for the card -->
                  <AnchorPane prefHeight="450.0" prefWidth="700.0" styleClass="card-shadow" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
            
                  <!-- Layer 2: The actual card with a clipped boundary -->
                  <AnchorPane prefHeight="450.0" prefWidth="700.0" styleClass="card-pane" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                     <clip>
                        <Rectangle arcHeight="30.0" arcWidth="30.0" height="450.0" width="700.0" />
                     </clip>
                     
                     <children>
                        <!-- Left Side Abstract Shapes (Capsules from Image) -->
                        <Group>
                           <!-- Shape 1: Top Right (Large Purple/Blue) - Tilted steep -->
                           <Rectangle arcHeight="100.0" arcWidth="100.0" height="400.0" layoutX="120.0" layoutY="-220.0" rotate="-25.0" styleClass="shape-purple" width="100.0" />
                           
                           <!-- Shape 2: Left Middle (Pink/Red) - Vertical sticking out -->
                           <Rectangle arcHeight="60.0" arcWidth="60.0" height="150.0" layoutX="-30.0" layoutY="120.0" styleClass="shape-pink" width="60.0" />
                           
                           <!-- Shape 3: Bottom Left (Blue/Cyan) - Diagonal -->
                           <Rectangle arcHeight="80.0" arcWidth="80.0" height="300.0" layoutX="-60.0" layoutY="300.0" rotate="-55.0" styleClass="shape-blue-violet" width="80.0" />
            
                           <!-- Shape 4: Bottom Right/Center (Deep Purple) - Tilted up -->
                           <Rectangle arcHeight="90.0" arcWidth="90.0" height="350.0" layoutX="220.0" layoutY="320.0" rotate="-35.0" styleClass="shape-deep-purple" width="90.0" />
                        </Group>
             
                        <!-- Right Side Form -->
                        <VBox alignment="CENTER" layoutX="350.0" prefHeight="450.0" prefWidth="350.0" spacing="10.0">
                           <children>
                              <Region VBox.vgrow="ALWAYS" />
                              <Text styleClass="login-header" text="User Login" />
                              <Region prefHeight="10.0" />
                              
                              <!-- Username Field -->
                              <HBox alignment="CENTER_LEFT" maxWidth="250.0" prefHeight="45.0" styleClass="input-group">
                                 <children>
                                    <SVGPath content="M12,12c2.21,0,4-1.79,4-4s-1.79-4-4-4s-4,1.79-4,4S9.79,12,12,12z M12,14c-2.67,0-8,1.34-8,4v2h16v-2C20,15.34,14.67,14,12,14z" fill="#adb5bd" scaleX="0.8" scaleY="0.8" />
                                    <TextField fx:id="usernameField" promptText="Username" styleClass="transparent-input" HBox.hgrow="ALWAYS" />
                                 </children>
                              </HBox>
                              
                              <!-- Password Field -->
                              <HBox alignment="CENTER_LEFT" maxWidth="250.0" prefHeight="45.0" styleClass="input-group">
                                 <children>
                                    <SVGPath content="M18,8h-1V6c0-2.76-2.24-5-5-5S7,3.24,7,6v2H6c-1.1,0-2,0.9-2,2v10c0,1.1,0.9,2,2,2h12c1.1,0,2-0.9,2-2V10C20,8.9,19.1,8,18,8z M9,6c0-1.66,1.34-3,3-3s3,1.34,3,3v2H9V6z" fill="#adb5bd" scaleX="0.8" scaleY="0.8" />
                                    <PasswordField fx:id="passwordField" promptText="Password" styleClass="transparent-input" HBox.hgrow="ALWAYS" />
                                 </children>
                              </HBox>
                              
                              <Label fx:id="messageLabel" textFill="#ff4757" wrapText="true" />
                              
                              <Button mnemonicParsing="false" onAction="#loginAction" prefHeight="45.0" prefWidth="250.0" styleClass="btn-login" text="LOGIN" />
                              
                              <Region prefHeight="10.0" />
                              <Text styleClass="link-text" text="Forgot Username / Password?" />
                              <Region prefHeight="15.0" />
                              <Text onMouseClicked="#openRegisterPage" styleClass="link-text" text="Create your Account →" />
                              <Region VBox.vgrow="ALWAYS" />
                           </children>
                        </VBox>
                     </children>
                  </AnchorPane>
               </children>
            </AnchorPane>
         </children>
      </StackPane>

      <!-- Window Controls (Must be last to be on top) -->
      <HBox alignment="TOP_RIGHT" spacing="8.0" styleClass="win-control-box" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleMinimize" styleClass="win-btn, win-btn-min" text="—" />
            <Button mnemonicParsing="false" onAction="#handleMaximize" styleClass="win-btn, win-btn-max" text="□" />
            <Button mnemonicParsing="false" onAction="#handleClose" styleClass="win-btn, win-btn-close" text="✕" />
         </children>
      </HBox>
   </children>
</AnchorPane>
