<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.text.Font?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<AnchorPane fx:id="rootPane" onMouseDragged="#onWindowDragged" onMousePressed="#onWindowPressed" prefHeight="900.0" prefWidth="1400.0" styleClass="dashboard-container" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.app.controller.ProfileController">
    <children>
        <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <!-- Sidebar -->
            <left>
                <VBox prefWidth="250.0" styleClass="sidebar">
                    <children>
                        <Label styleClass="sidebar-logo" text="Doctor App">
                            <VBox.margin>
                                <Insets bottom="50.0" left="25.0" right="25.0" top="30.0" />
                            </VBox.margin>
                        </Label>
                        
                        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                            <padding>
                                <Insets left="20.0" right="20.0" />
                            </padding>
                            <children>
                                <HBox alignment="CENTER_LEFT" onMouseClicked="#navDashboard" styleClass="menu-item">
                                    <children>
                                        <SVGPath content="M3,13h8V3H3V13z M3,21h8v-6H3V21z M13,21h8V11h-8V21z M13,3v6h8V3H13z" fill="#b8c2d1" />
                                        <Label text="Dashboard" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" onMouseClicked="#navPatients" styleClass="menu-item">
                                    <children>
                                        <SVGPath content="M12,12c2.21,0,4-1.79,4-4s-1.79-4-4-4s-4,1.79-4,4S9.79,12,12,12z M12,14c-2.67,0-8,1.34-8,4v2h16v-2C20,15.34,14.67,14,12,14z" fill="#b8c2d1" />
                                        <Label text="Patients" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" onMouseClicked="#navAppointments" styleClass="menu-item">
                                    <children>
                                        <SVGPath content="M19,3h-1V1h-2v2H8V1H6v2H5C3.89,3,3,3.9,3,5v14c0,1.1,0.89,2,2,2h14c1.1,0,2-0.9,2-2V5C21,3.9,20.11,3,19,3z M19,19H5V8h14V19z" fill="#b8c2d1" />
                                        <Label text="Appointment" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" onMouseClicked="#navTasks" styleClass="menu-item">
                                    <children>
                                        <SVGPath content="M19,3H14.82C14.4,1.84,13.3,1,12,1S9.6,1.84,9.18,3H5C3.9,3,3,3.9,3,5v14c0,1.1,0.9,2,2,2h14c1.1,0,2-0.9,2-2V5C21,3.9,20.1,3,19,3z M12,3c0.55,0,1,0.45,1,1s-0.45,1-1,1s-1-0.45-1-1S11.45,3,12,3z M10,17l-4-4l1.41-1.41L10,14.17l6.59-6.59L18,9L10,17z" fill="#b8c2d1" />
                                        <Label text="Tasks" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" onMouseClicked="#navProfile" styleClass="menu-item, active-menu-item">
                                    <children>
                                        <SVGPath content="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M12,5c1.66,0,3,1.34,3,3s-1.34,3-3,3 s-3-1.34-3-3S10.34,5,12,5z M12,19.2c-2.5,0-4.71-1.28-6-3.22c0.03-1.99,4-3.08,6-3.08s5.97,1.09,6,3.08 C16.71,17.92,14.5,19.2,12,19.2z" fill="WHITE" />
                                        <Label text="My Profile" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        
                        <HBox alignment="CENTER_LEFT" onMouseClicked="#navLogout" styleClass="menu-item, logout-item">
                            <children>
                                <SVGPath content="M17,7l-1.41,1.41L18.17,11H8v2h10.17l-2.58,2.58L17,17l5-5L17,7z M4,5h8V3H4C2.9,3,2,3.9,2,5v14c0,1.1,0.9,2,2,2h8v-2H4V5z" fill="#b8c2d1" />
                                <Label text="Logout" />
                            </children>
                            <VBox.margin>
                                <Insets bottom="30.0" left="20.0" right="20.0" />
                            </VBox.margin>
                        </HBox>
                    </children>
                </VBox>
            </left>
            
            <!-- Center Main Content -->
            <center>
                <VBox styleClass="main-content">
                    <children>
                        <!-- Top Nav / Search bar -->
                        <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="20.0" styleClass="top-nav">
                            <children>
                                <HBox alignment="CENTER_LEFT" styleClass="search-box" HBox.hgrow="ALWAYS">
                                    <children>
                                        <SVGPath content="M15.5,14h-0.79l-0.28-0.27C15.41,12.59,16,11.11,16,9.5C16,5.91,13.09,3,9.5,3S3,5.91,3,9.5S5.91,16,9.5,16 c1.61,0,3.09-0.59,4.23-1.57l0.27,0.28v0.79l5,4.99L20.49,19L15.5,14z M9.5,14C7.01,14,5,11.99,5,9.5S7.01,5,9.5,5S14,7.01,14,9.5 S11.99,14,9.5,14z" fill="#7f8fa6" />
                                        <TextField promptText="Search Anything..." styleClass="search-input" HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER" spacing="25.0">
                                    <children>
                                        <SVGPath content="M12,22c1.1,0,2-0.9,2-2h-4C10,21.1,10.9,22,12,22z M18,16v-5c0-3.07-1.63-5.64-4.5-6.32V4c0-0.83-0.67-1.5-1.5-1.5 s-1.5,0.67-1.5,1.5v0.68C7.64,5.36,6,7.92,6,11v5l-2,2v1h16v-1L18,16z" fill="#7f8fa6" />
                                        <Label fx:id="nameLabelTop" text="Dr. User Name" styleClass="user-name-label" />
                                    </children>
                                </HBox>
                            </children>
                            <padding>
                                <Insets left="30.0" right="30.0" />
                            </padding>
                        </HBox>
                        
                        <ScrollPane fitToWidth="true" styleClass="content-scroll" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox spacing="30.0" styleClass="content-area">
                                    <padding>
                                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                                    </padding>
                                    <children>
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <VBox>
                                                    <children>
                                                        <Label styleClass="section-title" text="Account Settings" />
                                                        <Label styleClass="dim-label" text="Manage your professional profile and account security" />
                                                    </children>
                                                </VBox>
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Button mnemonicParsing="false" onAction="#navDashboard" styleClass="btn-white-sm" text="Discard Changes" />
                                                <Region prefWidth="15.0" />
                                                <Button mnemonicParsing="false" onAction="#saveChangesAction" styleClass="btn-primary" text="Save Changes" />
                                            </children>
                                        </HBox>

                                        <HBox spacing="30.0">
                                            <children>
                                                <!-- Left Card: Profile Image & Basic Info -->
                                                <VBox styleClass="card" prefWidth="400.0" spacing="25.0">
                                                    <children>
                                                        <Label text="Profile Photo" styleClass="section-title-large" />
                                                        <VBox alignment="CENTER" spacing="20.0">
                                                            <children>
                                                                <StackPane maxHeight="-Infinity" maxWidth="-Infinity">
                                                                    <children>
                                                                        <Circle fill="#f1f2f6" radius="75.0" stroke="#e1e2e6" strokeType="INSIDE" />
                                                                        <ImageView fx:id="profileImage" fitHeight="140.0" fitWidth="140.0" pickOnBounds="true" preserveRatio="true" />
                                                                    </children>
                                                                </StackPane>
                                                                <VBox alignment="CENTER" spacing="10.0">
                                                                    <children>
                                                                        <Button onAction="#uploadPhotoAction" styleClass="btn-white-sm" text="Upload New Photo" />
                                                                        <Label text="Recommended: 400x400px JPG or PNG" styleClass="dim-label-sm" />
                                                                    </children>
                                                                </VBox>
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="15.0">
                                                            <children>
                                                                <Label text="Username" styleClass="field-label" />
                                                                <TextField fx:id="usernameVal" editable="false" styleClass="text-field-readonly" />
                                                                
                                                                <Label text="Professional Role" styleClass="field-label" />
                                                                 <ComboBox fx:id="roleBox" maxWidth="1.7976931348623157e308">
                                                                    <items>
                                                                        <FXCollections fx:factory="observableArrayList">
                                                                            <String fx:value="Doctor" />
                                                                            <String fx:value="Stagiaire" />
                                                                            <String fx:value="Secretaire" />
                                                                        </FXCollections>
                                                                    </items>
                                                                </ComboBox>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </VBox>

                                                <!-- Right Card: Detailed Information -->
                                                <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="25.0">
                                                    <children>
                                                        <Label text="Personal Information" styleClass="section-title-large" />
                                                        <GridPane hgap="25.0" vgap="25.0" VBox.vgrow="ALWAYS">
                                                            <columnConstraints>
                                                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                                                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                                                            </columnConstraints>
                                                            <children>
                                                                <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                                                    <children>
                                                                        <Label text="First Name" styleClass="field-label" />
                                                                        <TextField fx:id="firstNameField" promptText="Your first name" />
                                                                    </children>
                                                                </VBox>
                                                                <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                                                    <children>
                                                                        <Label text="Last Name" styleClass="field-label" />
                                                                        <TextField fx:id="lastNameField" promptText="Your last name" />
                                                                    </children>
                                                                </VBox>
                                                                <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                                                    <children>
                                                                        <Label text="Email Address" styleClass="field-label" />
                                                                        <TextField fx:id="emailField" promptText="you@example.com" />
                                                                    </children>
                                                                </VBox>
                                                                <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                                                    <children>
                                                                        <Label text="Phone Number" styleClass="field-label" />
                                                                        <TextField fx:id="phoneField" promptText="+1 234 567 890" />
                                                                    </children>
                                                                </VBox>
                                                                <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                                                    <children>
                                                                        <Label text="Gender" styleClass="field-label" />
                                                                         <ComboBox fx:id="genderBox" maxWidth="1.7976931348623157e308">
                                                                            <items>
                                                                                <FXCollections fx:factory="observableArrayList">
                                                                                    <String fx:value="Male" />
                                                                                    <String fx:value="Female" />
                                                                                </FXCollections>
                                                                            </items>
                                                                        </ComboBox>
                                                                    </children>
                                                                </VBox>
                                                            </children>
                                                            <rowConstraints>
                                                                <RowConstraints />
                                                                <RowConstraints />
                                                                <RowConstraints />
                                                            </rowConstraints>
                                                        </GridPane>
                                                        
                                                        <Region VBox.vgrow="ALWAYS" />
                                                        
                                                        <HBox alignment="BOTTOM_RIGHT" spacing="15.0">
                                                            <children>
                                                                <Button onAction="#deleteAccountAction" styleClass="btn-outline-danger" text="Delete Account" />
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>
            </center>
        </BorderPane>

        <!-- Window Controls -->
        <HBox alignment="TOP_RIGHT" spacing="8.0" styleClass="win-control-box" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Button onAction="#handleMinimize" styleClass="win-btn, win-btn-min" text="—" />
                <Button onAction="#handleMaximize" styleClass="win-btn, win-btn-max" text="□" />
                <Button onAction="#handleClose" styleClass="win-btn, win-btn-close" text="✕" />
            </children>
        </HBox>
    </children>
</AnchorPane>
